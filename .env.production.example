# Production template for pmi-edu.com
# Copy to server: cp .env.production.example .env

# --- Domain ---
APP_DOMAIN=https://pmi-edu.com
ALLOWED_ORIGINS=https://pmi-edu.com,https://www.pmi-edu.com

# --- Security (CHANGE ALL) ---
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
ALLOW_REGISTRATION=false
REGISTRATION_SECRET=
ADMIN_USERNAMES=admin

# --- Database / Queue ---
DATABASE_URL=postgresql://postgres:REPLACE_WITH_STRONG_DB_PASSWORD@db:5432/pdf_translator
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- Translation API keys (server-side only) ---
GEMINI_API_KEY=
DEEPL_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# --- Private object storage (MinIO) ---
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=https://storage.pmi-edu.com
S3_ACCESS_KEY=REPLACE_MINIO_USER
S3_SECRET_KEY=REPLACE_MINIO_PASSWORD
S3_BUCKET_NAME=pdf-translator-assets
S3_PRESIGNED_EXPIRY=3600

# --- Optional ---
SENTRY_DSN=
CLEANUP_INTERVAL_HOURS=24
