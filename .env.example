# Copy this file to .env and fill in your values.

# JWT secret (required in production)
SECRET_KEY=change-me-to-a-long-random-string

# Registration control
ALLOW_REGISTRATION=true
# Optional invite code required for new signups (leave empty to disable)
REGISTRATION_SECRET=

# Comma-separated browser origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database (SQLite local | PostgreSQL Docker | Supabase cloud)
# Supabase (Vercel/serverless): use Transaction pooler port 6543 — see SUPABASE.md
# Supabase (Docker/worker): use Direct connection port 5432
DATABASE_URL=sqlite:///./pdf_translator.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# Translation API keys (optional on frontend when set here)
GEMINI_API_KEY=
DEEPL_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
LIBRETRANSLATE_API_KEY=

# Supabase (database + optional Storage for PDF/audio)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=media
SUPABASE_SIGNED_URL_EXPIRY=604800
S3_ENDPOINT_URL=
S3_PUBLIC_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=pdf-translator-assets
S3_PRESIGNED_EXPIRY=3600

# Admin usernames (comma-separated)
ADMIN_USERNAMES=admin

# Monitoring (optional)
SENTRY_DSN=

# File cleanup interval in hours
CLEANUP_INTERVAL_HOURS=24
